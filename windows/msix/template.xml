<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="ClaudePanel"
        Arguments=""
        InstallLocation="C:\Program Files\ClaudePanel\Claude Panel">
    </Installer>
    <PackageInformation
        PackageName="Claude Panel"
        PackageDisplayName="Claude Panel"
        PublisherName="CN=ClaudePanel"
        PublisherDisplayName="ClaudePanel"
        Version="0.1.0.0"
        PackageDescription="Claude Code Usage Panel">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.claudepanel.pkg"
                Description="Claude Code Usage Panel"
                DisplayName="Claude Panel"
                ExecutableName="ClaudePanel"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Claude Panel</DisplayName>
            <PublisherDisplayName>ClaudePanel</PublisherDisplayName>
            <Description>Claude Code Usage Panel</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="claudepanel.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
