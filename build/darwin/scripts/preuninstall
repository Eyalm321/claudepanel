#!/bin/bash
# preuninstall — invoked when removing ClaudeBar via a separate uninstall
# helper. Apple's `installer` does not support .pkg uninstall natively, so
# this script is shipped alongside the app bundle and referenced by the
# in-app "Uninstall ClaudeBar" action documented in README.

set -u

TARGET_USER="${USER:-$(stat -f '%Su' /dev/console 2>/dev/null || echo '')}"
if [ -z "$TARGET_USER" ] || [ "$TARGET_USER" = "root" ]; then
    echo "ClaudeBar preuninstall: could not determine GUI user; skipping statusline removal."
    exit 0
fi

USER_HOME=$(/usr/bin/dscl . -read "/Users/$TARGET_USER" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')
if [ -z "$USER_HOME" ] || [ ! -d "$USER_HOME" ]; then
    USER_HOME=$(eval echo "~$TARGET_USER")
fi

SETTINGS_PATH="$USER_HOME/.claude/settings.json"

/usr/bin/sudo -u "$TARGET_USER" /usr/bin/python3 - "$SETTINGS_PATH" uninstall <<'PYEOF'
import json, os, sys, tempfile

path = sys.argv[1]
mode = sys.argv[2]

if not os.path.exists(path):
    sys.exit(0)

try:
    with open(path, "r") as f:
        data = f.read().strip()
        settings = json.loads(data) if data else {}
    if not isinstance(settings, dict):
        sys.exit(0)
except json.JSONDecodeError:
    sys.exit(0)

settings.pop("statuslineCommand", None)

tmp_fd, tmp_path = tempfile.mkstemp(dir=os.path.dirname(path), prefix=".settings.", suffix=".tmp")
try:
    with os.fdopen(tmp_fd, "w") as f:
        json.dump(settings, f, indent=2)
    os.replace(tmp_path, path)
    print(f"ClaudeBar: statusline {mode} complete ({path})")
except Exception:
    try:
        os.unlink(tmp_path)
    except OSError:
        pass
    raise
PYEOF

exit 0
