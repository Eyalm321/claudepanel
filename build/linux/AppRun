#!/bin/sh
# AppRun — entry point invoked when the AppImage is executed.
# AppImage automatically sets $APPDIR to the mount point.

HERE="$(dirname "$(readlink -f "${0}")")"
export PATH="${HERE}/usr/bin:${PATH}"
export GST_PLUGIN_PATH="${HERE}/usr/lib/gstreamer-1.0"
exec "${HERE}/usr/bin/claudepanel" "$@"
